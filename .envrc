# .envrc - dijalankan otomatis oleh direnv setiap masuk folder ini.
#
# PATH_add adalah fungsi bawaan direnv yang menambahkan folder ke paling DEPAN
# variable $PATH, khusus selama kita berada di folder ini.
# Karena folder .bin/ berisi "php" (symlink ke php84) dan "composer" (wrapper script),
# begitu kita ketik "php" atau "composer" di terminal, sistem akan menemukan
# file KITA duluan (di .bin/) sebelum menemukan /usr/bin/php (versi 8.5 sistem).
PATH_add .bin

echo "✅ Environment pemira-app aktif: $(php -v | head -n 1)"
